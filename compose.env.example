# Compose deployment variables
# Copy this file to .env, then edit the values before running:
# docker compose pull
# docker compose up -d

# Published image to deploy (no local build required)
OUTLOOKEMAIL_IMAGE=ghcr.io/Thinker-Joe/outlookemail:latest
OUTLOOKEMAIL_CONTAINER_NAME=outlook-mail-reader
OUTLOOKEMAIL_PORT=5000
OUTLOOKEMAIL_DATA_DIR=./data

# Application settings
SECRET_KEY=change-me-before-production
LOGIN_PASSWORD=admin123
FLASK_ENV=production

# Runtime tuning
GUNICORN_TIMEOUT=300
GUNICORN_THREADS=4
IMAP_TIMEOUT=45

# Temp mail providers
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=gpt-test
DUCKMAIL_BASE_URL=https://api.duckmail.sbs
DUCKMAIL_API_KEY=

# Cloudflare Temp Email (optional)
CLOUDFLARE_WORKER_DOMAIN=
CLOUDFLARE_EMAIL_DOMAINS=
CLOUDFLARE_ADMIN_PASSWORD=

# OAuth (optional)
OAUTH_CLIENT_ID=
OAUTH_REDIRECT_URI=
