# Docker Compose / runtime example variables
# Copy this file to .env, then edit values before running:
# docker compose pull
# docker compose up -d

# Published image to deploy
OUTLOOKEMAIL_IMAGE=ghcr.io/Thinker-Joe/outlookemail:latest
OUTLOOKEMAIL_CONTAINER_NAME=outlook-mail-reader
OUTLOOKEMAIL_PORT=5000
OUTLOOKEMAIL_DATA_DIR=./data

# Flask 配置
# 必须设置！使用以下命令生成：python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# 登录密码（默认：admin123，首次启动后会自动哈希存储）
# 建议首次启动后立即通过 Web 界面修改为强密码（至少8位）
LOGIN_PASSWORD=admin123

# 应用配置
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production

# 数据库路径
DATABASE_PATH=data/outlook_accounts.db

# Gunicorn / IMAP
GUNICORN_TIMEOUT=300
GUNICORN_THREADS=4
IMAP_TIMEOUT=45

# GPTMail 临时邮箱配置
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=gpt-test

# DuckMail 临时邮箱配置
DUCKMAIL_BASE_URL=https://api.duckmail.sbs
DUCKMAIL_API_KEY=

# Cloudflare Temp Email（可选）
CLOUDFLARE_WORKER_DOMAIN=
CLOUDFLARE_EMAIL_DOMAINS=
CLOUDFLARE_ADMIN_PASSWORD=

# OAuth2 配置（可选，不填使用默认值）
OAUTH_CLIENT_ID=
OAUTH_REDIRECT_URI=
